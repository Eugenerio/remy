# Minimal ComfyUI stub for local e2e tests. Responds to /prompt with a
# fixed fake job id. Used when the AI service has MOCK_COMFY=1.
FROM python:3.11-slim
WORKDIR /app
RUN pip install fastapi uvicorn
COPY scripts/comfy_stub.py /app/stub.py
EXPOSE 8188
CMD ["uvicorn", "stub:app", "--host", "0.0.0.0", "--port", "8188"]
