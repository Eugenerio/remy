{
  "name": "remy",
  "version": "0.1.0",
  "private": true,
  "description": "Remy — SaaS platform for creating and scaling AI influencers",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter='./apps/*' dev",
    "dev:web": "pnpm --filter @remy/web dev",
    "dev:api": "pnpm --filter @remy/api dev",
    "dev:ai": "cd services/ai && uv run uvicorn app.main:app --reload --port 8001",
    "dev:infra": "docker compose -f infra/docker/compose.dev.yml up",
    "build": "pnpm -r --filter='./apps/*' --filter='./packages/*' build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @remy/web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "db:generate": "pnpm --filter @remy/api db:generate",
    "db:migrate": "pnpm --filter @remy/api db:migrate",
    "db:seed": "pnpm --filter @remy/api db:seed",
    "db:studio": "pnpm --filter @remy/api db:studio",
    "clean": "pnpm -r exec rm -rf node_modules dist .next .turbo && rm -rf node_modules",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": "prettier --write",
    "*.{json,md,yml,yaml}": "prettier --write"
  }
}
