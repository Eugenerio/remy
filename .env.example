# ============================================================================
# Remy — root .env.example
# Copy to .env and fill in. Each service also has its own .env.example.
# ============================================================================

# Deployment
NODE_ENV=development

# Public URLs
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000
PUBLIC_AI_URL=http://localhost:8001

# -------------------------------------------------------------------------
# Supabase — database, auth, storage
# For cloud: create a project at https://supabase.com and copy from Settings.
# For local: `supabase start` (requires supabase CLI + Docker).
# -------------------------------------------------------------------------
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
SUPABASE_PROJECT_REF=

# Database connections (Prisma uses direct; Supabase pgbouncer is pooled)
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres?schema=public&pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:postgres@localhost:54322/postgres?schema=public

# Redis (job queue + cache). Railway provides a managed Redis; dev uses container.
REDIS_URL=redis://localhost:6379

# -------------------------------------------------------------------------
# Supabase Storage buckets (created by migration seed)
# -------------------------------------------------------------------------
SUPABASE_BUCKET_UPLOADS=uploads
SUPABASE_BUCKET_GENERATIONS=generations
SUPABASE_BUCKET_DATASETS=datasets

# Auth config (Supabase Auth handles the heavy lifting; these are our extras)
AUTH_COOKIE_NAME=remy-auth
AUTH_MAGIC_LINK_TTL_SECONDS=900

# Email (Resend for prod; Supabase's inbucket at :54324 for dev)
EMAIL_FROM=noreply@remy.local
RESEND_API_KEY=re_xxx

# Stripe (billing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_SCALE=price_xxx
STRIPE_PRICE_TOPUP_100=price_xxx
STRIPE_PRICE_TOPUP_500=price_xxx
STRIPE_PRICE_TOPUP_2000=price_xxx

# Modal (GPU compute)
MODAL_TOKEN_ID=ak-xxx
MODAL_TOKEN_SECRET=as-xxx
MODAL_APP_NAME=remy
MODAL_WEBHOOK_SECRET=change-me

# ComfyUI (deployed as a Modal app or on Railway GPU). For MVP we front
# ComfyUI via Modal functions, so the AI service rarely talks to it directly.
COMFYUI_URL=https://your-comfyui.modal.run
COMFYUI_API_KEY=

# Gemini (Google AI) — used by the AI service for outfit analysis
# Create a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# TikTok (trend source ingestion)
TIKTOK_RAPIDAPI_KEY=
TIKTOK_RAPIDAPI_HOST=tiktok-scraper7.p.rapidapi.com

# Observability
SENTRY_DSN=
SENTRY_ENV=development
OTEL_EXPORTER_OTLP_ENDPOINT=

# Admin
ADMIN_EMAILS=you@example.com

# Service-to-service auth (shared secret between web<->api<->ai<->modal webhooks)
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token
